# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git — it is already listed in .gitignore.

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# RudderStack CDP
NEXT_PUBLIC_RUDDERSTACK_WRITE_KEY=your_write_key_here
NEXT_PUBLIC_RUDDERSTACK_DATA_PLANE_URL=https://your-data-plane-url.rudderstack.com

# GA4 Measurement ID (reference only — configured as RudderStack destination)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# CookieYes — paste only the ID from your script src URL
# src="https://cdn-cookieyes.com/client_data/[THIS_PART]/script.js"
NEXT_PUBLIC_COOKIEYES_SCRIPT_ID=your_cookieyes_script_id

# HubSpot
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=your_portal_id
# Find in HubSpot → Marketing → Forms → [Form] → Actions → Share → Embed Code
NEXT_PUBLIC_HUBSPOT_FORM_GUID=your_form_guid

# Calendly event URL (the full URL to your specific event type)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/event-name
