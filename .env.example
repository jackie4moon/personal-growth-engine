# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git — it is already listed in .gitignore.

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# RudderStack CDP
NEXT_PUBLIC_RUDDERSTACK_WRITE_KEY=your_write_key_here
NEXT_PUBLIC_RUDDERSTACK_DATA_PLANE_URL=https://your-data-plane-url.rudderstack.com

# GA4 Measurement ID (reference only — configured as RudderStack destination, not used in code)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
